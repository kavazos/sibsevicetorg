# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@your-neon-pool.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Site
SITE_URL="https://yourdomain.com"
SITE_NAME="Сибсервисторг"

# Admin
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_password
SESSION_SECRET=your_secret_key_change_in_prod

# Email (SMTP for sending notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=info@sibservistorg.ru
CONTACT_EMAIL=info@sibservistorg.ru

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email (alternative via Resend)
# RESEND_API_KEY=your_resend_key
